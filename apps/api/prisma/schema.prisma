// KabzıMall — Intelligence kalıcı şeması (Teknik doküman Bölüm 3).
// Konvansiyon: uuid PK, tenant_id (çok-kiracılık), created_at/updated_at,
// para alanları integer kuruş. price_history append-only (üzerine yazılmaz).
// Not: tenant_id şimdilik sabit DEV tenant ile çözülür (auth gelince token'dan).
// RLS (satır seviyesi izolasyon) auth adımıyla birlikte eklenecek.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Teslimat bölgesi (Faz 1: ilçe adı listesi). İleride PostGIS poligon (v1.1 §3).
model DeliveryZone {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([tenantId, name])
  @@map("delivery_zones")
}

/// Hazır sepet içeriği: bir BASKET ürününün hangi ürünlerden kaç adet/kg
/// içerdiği (v1.1 §8). Sepet AYRI BİR ÜRÜNDÜR (kendi fiyatı/indirimi var);
/// içerik yalnızca müşteriye gösterim + paketleme/toplama içindir.
model ProductComponent {
  id          String @id @default(uuid()) @db.Uuid
  parentId    String @map("parent_id") @db.Uuid
  componentId String @map("component_id") @db.Uuid
  qty         Float

  parent    Product @relation("BasketParent", fields: [parentId], references: [id], onDelete: Cascade)
  component Product @relation("BasketComponent", fields: [componentId], references: [id])

  @@map("product_components")
}

/// Ürün kategorisi (Teknik doküman Bölüm 3.2).
model Category {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  slug      String
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  products Product[]

  @@unique([tenantId, slug])
  @@map("categories")
}

/// Katalog çekirdeği (Teknik doküman Bölüm 3.2). client `productId` = slug.
/// /intel/price/apply base_price'ı yazar; katalog ekranı diğer alanları yönetir.
model Product {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  slug         String
  name         String   @default("")
  /// SIMPLE (normal ürün) | BASKET (hazır sepet — kendi fiyatı + içeriği).
  kind         String   @default("SIMPLE")
  categoryId   String?  @map("category_id") @db.Uuid
  /// WEIGHT | PIECE | BUNCH | PACK | VARIABLE_WEIGHT_PACK
  saleType     String   @default("WEIGHT") @map("sale_type")
  unitLabel    String?  @map("unit_label")
  imageUrl     String?  @map("image_url")
  /// Ürün açıklaması (vitrin detay sayfası). Yöresel ürünlerde köken/içerik anlatısı.
  description  String?  @db.Text
  /// Mevcut stok (kg/adet). null = stok takibi yok (sınırsız); 0 = tükendi.
  stockQty     Float?   @map("stock_qty")
  /// Sipariş başına azami miktar (kg/adet). null = sınır yok.
  maxPerOrder  Float?   @map("max_per_order")
  /// Yayınlanan mağaza fiyatı (kuruş). Henüz uygulanmadıysa null.
  basePrice    Int?     @map("base_price")
  /// İndirimli fiyat (kuruş). Taban fiyatın altındaysa vitrinde geçerli olur.
  discountedPrice Int?  @map("discounted_price")
  originRegion String?  @map("origin_region")
  /// Son otomatik indirim (markdown) uygulanma anı. null = indirim elle/hiç.
  /// Restokta işaretli indirim otomatik temizlenir; günde bir kez uygulanır.
  markdownAt   DateTime? @map("markdown_at") @db.Timestamptz(6)
  isActive     Boolean  @default(true) @map("is_active")
  isFeatured   Boolean  @default(false) @map("is_featured")
  isFreshDaily Boolean  @default(false) @map("is_fresh_daily")
  isLocal      Boolean  @default(false) @map("is_local")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  category     Category?      @relation(fields: [categoryId], references: [id])
  priceHistory PriceHistory[]
  orderItems   OrderItem[]
  components    ProductComponent[] @relation("BasketParent")
  inBaskets     ProductComponent[] @relation("BasketComponent")
  stockMovements StockMovement[]
  substitutes    ProductSubstitute[] @relation("SubstituteOf")
  substituteFor  ProductSubstitute[] @relation("SubstituteFor")

  @@unique([tenantId, slug])
  @@index([tenantId, categoryId])
  @@map("products")
}

/// Mağaza geneli ayarlar (tenant başına tek satır). Faz 1: asgari sipariş tutarı.
model StoreSetting {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @unique @map("tenant_id") @db.Uuid
  /// Asgari sipariş ara toplamı (kuruş). 0 = sınır yok.
  minOrderTotal Int      @default(0) @map("min_order_total")
  /// Kademeli teslimat tarifesi: [{minSubtotal, fee}] (kuruş). Artan eşik;
  /// sepet ara toplamının geçtiği en yüksek kademe uygulanır (fee 0 = ücretsiz).
  deliveryTiers Json     @map("delivery_tiers")
  /// Teslimat saat pencereleri (["10:00-13:00",...]) — panelden düzenlenir; boşsa varsayılan 3 pencere.
  deliveryWindows Json?  @map("delivery_windows")
  /// Teslimat penceresi başına azami sipariş (null = sınırsız). Dolan pencere satışa kapanır.
  slotCapacity  Int?     @map("slot_capacity")
  /// Dükkân/depo başlangıç noktası — rota optimizasyonu buradan başlar/biter.
  depotLat      Float?   @map("depot_lat")
  depotLng      Float?   @map("depot_lng")
  /// İletişim bilgileri — web'in İletişim sayfası ve alt bilgisi buradan beslenir.
  contactPhone     String? @map("contact_phone")
  contactWhatsapp  String? @map("contact_whatsapp")
  contactEmail     String? @map("contact_email")
  contactAddress   String? @map("contact_address")
  contactInstagram String? @map("contact_instagram")
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("store_settings")
}

/// Müşteri siparişi (Market — Faz 1: misafir + kapıda ödeme). Tutarlar kuruş.
model Order {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  code           String   @unique
  customerName   String   @map("customer_name")
  customerPhone  String   @map("customer_phone")
  addressText    String   @map("address_text")
  district       String?
  /// Haritadan seçilen teslimat noktası (WGS84). Rota optimizasyonunu besler.
  lat            Float?
  lng            Float?
  /// Ürün eksik/tükenmiş çıkarsa: CALL (beni ara) | REMOVE (çıkar, tutarı düş) | SUBSTITUTE (benzeriyle değiştir).
  substitutionPref String @default("CALL") @map("substitution_pref")
  /// Sipariş bildirimleri için opsiyonel e-posta (checkout'ta isteğe bağlı).
  customerEmail  String?  @map("customer_email")
  /// Bekleyen teslimat saati değişikliği talebi — admin onaylayınca deliveryDate/Window'a işlenir.
  slotChangeDate   DateTime? @map("slot_change_date") @db.Date
  slotChangeWindow String?   @map("slot_change_window")
  slotChangeStatus String?   @map("slot_change_status")
  /// Teslimat sonrası müşteri puanı (1-5) + yorumu; tek sefer verilir.
  rating          Int?
  ratingComment   String?    @map("rating_comment")
  note           String?
  status         String   @default("CONFIRMED")
  /// Satış kanalı: WEB (site siparişi) | POS (tezgâh satışı — doğuştan DELIVERED,
  /// stok/kasa/ciro aynı yoldan işler; sipariş listesi/pano/müşteri kartlarına girmez).
  channel        String   @default("WEB")
  paymentMethod  String   @default("COD") @map("payment_method")
  /// Ertesi gün teslimat slotu (Faz 1: SCHEDULED).
  deliveryDate   DateTime? @map("delivery_date") @db.Date
  deliveryWindow String?   @map("delivery_window")
  subtotal       Int
  /// Uygulanan kupon (varsa) ve indirimi (kuruş). grandTotal = subtotal − discount + fee.
  couponCode     String?  @map("coupon_code")
  discountTotal  Int      @default(0) @map("discount_total")
  deliveryFee    Int      @map("delivery_fee")
  grandTotal     Int      @map("grand_total")
  /// Tartılı ürünlerde ön provizyon tutarı (sipariş anı tahmini).
  estimatedTotal Int      @map("estimated_total")
  /// Paketleme sonrası gerçek gramajla kesinleşen tutar (henüz paketlenmediyse null).
  finalTotal     Int?     @map("final_total")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  items         OrderItem[]
  notifications Notification[]
  statusHistory OrderStatusHistory[]
  refunds       OrderRefund[]

  @@index([tenantId, status])
  @@index([tenantId, channel, createdAt])
  @@map("orders")
}

/// Kısmi iade: teslim edilmiş siparişte seçili kalemler için nakit (kasadan
/// SALE_REVERSAL) ya da kupon iadesi. K-Z net ciroyu bu kayıtlardan düşer.
/// Toplam iadeler tahsilatı aşamaz; kısmi iadesi olan sipariş tam iptal edilemez.
model OrderRefund {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  orderId    String   @map("order_id") @db.Uuid
  /// İade tutarı (kuruş).
  amount     Int
  /// CASH (kasadan nakit) | COUPON (tek kullanımlık sabit kupon).
  method     String
  /// method=COUPON ise üretilen kupon kodu.
  couponCode String?  @map("coupon_code")
  reason     String?
  /// Kalem dökümü: [{ itemId, productName, qty, amount }].
  items      Json
  /// Ürünler stoğa geri alındı mı (çürük/fire ise false).
  restock    Boolean  @default(false)
  createdBy  String?  @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId, orderId])
  @@index([tenantId, createdAt])
  @@map("order_refunds")
}

/// Sipariş durumu geçmişi (Teknik §6.1 order_status_history). Her geçiş için
/// bir satır: kimden→kime, kim yaptı, ne zaman. İzlenebilirlik + müşteri zaman çizelgesi.
model OrderStatusHistory {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  orderId    String   @map("order_id") @db.Uuid
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  /// Değişikliği yapan (personel e-postası ya da "müşteri"/"sistem").
  changedBy  String?  @map("changed_by")
  note       String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId, orderId])
  @@map("order_status_history")
}

/// Müşteri bildirimi (sipariş durumu/paketleme). Şimdilik LOG; ileride SMS/push.
/// Kupon: PERCENT (yüzde) ya da FIXED (kuruş) indirim; asgari sepet + son
/// kullanma + kullanım limiti. Kod tenant içinde benzersiz, BÜYÜK harf saklanır.
model Coupon {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  code        String
  type        String // PERCENT | FIXED
  value       Int // PERCENT: 1-100, FIXED: kuruş
  minSubtotal Int       @default(0) @map("min_subtotal")
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz(6)
  maxUses     Int?      @map("max_uses")
  usedCount   Int       @default(0) @map("used_count")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([tenantId, code])
  @@map("coupons")
}

/// İkame ürün: stok bitince paketleyiciye ve müşteriye önerilecek
/// alternatifler (sıralı, ürün başına en fazla 5).
model ProductSubstitute {
  id           String @id @default(uuid()) @db.Uuid
  tenantId     String @map("tenant_id") @db.Uuid
  productId    String @map("product_id") @db.Uuid
  substituteId String @map("substitute_id") @db.Uuid
  sortOrder    Int    @default(0) @map("sort_order")

  product    Product @relation("SubstituteOf", fields: [productId], references: [id], onDelete: Cascade)
  substitute Product @relation("SubstituteFor", fields: [substituteId], references: [id], onDelete: Cascade)

  @@unique([productId, substituteId])
  @@index([tenantId, productId])
  @@map("product_substitutes")
}

/// Destek talebi: web iletişim formundan gelir; admin yanıtlar/kapatır.
/// Yanıt müşteriye e-postayla gider (MailService — anahtar yoksa LOG modu).
model SupportTicket {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  email     String?
  phone     String?
  orderCode String?  @map("order_code")
  message   String
  status    String   @default("OPEN") // OPEN | CLOSED
  reply     String?
  repliedBy String?  @map("replied_by")
  ip        String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("support_tickets")
}

/// Stok hareket defteri: stok takipli üründe her değişim iz bırakır.
/// ORDER (sipariş düşümü) | CANCEL (iptalde geri yükleme) | MANUAL (elle giriş/düzeltme).
model StockMovement {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  delta     Float // +giriş / −çıkış (ürünün birimi cinsinden)
  reason    String // ORDER | CANCEL | MANUAL
  refCode   String?  @map("ref_code") // sipariş kodu vb.
  actor     String? // elle değişimde kullanıcı e-postası
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Ürün silinirse hareket defteri de gider (fiyat geçmişi restrict kalır — bilinçli fark:
  // ürün silme zaten yalnız fiyat geçmişi olmayan ürünlerde mümkün).
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId, productId])
  @@index([tenantId, createdAt])
  @@map("stock_movements")
}

/// Vitrin duyurusu — ana sayfadaki promo alanını panelden yönetir.
/// Aktif banner'lardan sortOrder'ı en küçük olan gösterilir; couponCode
/// doluysa müşteriye kopyalanabilir kupon rozetiyle sunulur.
model Banner {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  kicker     String? // üst küçük etiket (ör. "Taze · Yöresel")
  title      String
  subtitle   String?
  couponCode String?  @map("coupon_code")
  sortOrder  Int      @default(0) @map("sort_order")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("banners")
}

/// Müşteri e-posta OTP girişi: kod hash'lenir, 5 dk geçerli, 5 deneme hakkı.
/// Doğrulanınca müşteri JWT'si verilir (kind: customer — personel uçlarına GEÇMEZ).
model CustomerOtp {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  email      String
  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  attempts   Int       @default(0)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId, email])
  @@map("customer_otps")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  channel   String   @default("LOG")
  message   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId, orderId])
  @@map("notifications")
}

/// Sipariş kalemi. unit_price/product_name sipariş anındaki anlık görüntüdür.
model OrderItem {
  id          String  @id @default(uuid()) @db.Uuid
  orderId     String  @map("order_id") @db.Uuid
  productId   String  @map("product_id") @db.Uuid
  productName String  @map("product_name")
  unitLabel   String? @map("unit_label")
  unitPrice   Int     @map("unit_price")
  orderedQty  Float   @map("ordered_qty")
  /// Paketlemede tartılan gerçek miktar (girilene dek null).
  pickedQty   Float?  @map("picked_qty")
  /// Satış anındaki birim maliyet (kuruş) — K/Z COGS tarihsel maliyetle hesaplansın
  /// (bugünkü hal fiyatı geçmiş siparişi çarpmasın). Maliyet tanımsızsa null.
  unitCostSnapshot Int? @map("unit_cost_snapshot")
  /// Müşteri ürün notu (ör. "çok olgun olmasın") — paketleyene iletilir.
  note        String?
  lineTotal   Int     @map("line_total")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

/// Fiyat değişiklik geçmişi — append-only ("bu fiyat neden böyle?" izlenebilir).
model PriceHistory {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  oldPrice        Int?     @map("old_price")
  newPrice        Int      @map("new_price")
  strategyApplied String   @map("strategy_applied")
  reason          String?
  netMargin       Float?   @map("net_margin")
  changedBy       String?  @map("changed_by")
  changedAt       DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id])

  @@index([tenantId, productId])
  @@map("price_history")
}

/// Panel kullanıcısı (personel). Müşteri auth'u (OTP) ayrı gelecek — bu, admin/
/// Intelligence girişidir. Rol: ADMIN | PRICE_MANAGER | OPERATION | VIEWER (Bölüm 7).
model User {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  role         String   @default("VIEWER")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("users")
}

/// Hal veri kaynağı → katalog eşlemesi. Dış kaynak (İBB) ürün adını bizim
/// ürün slug'ımıza bağlar; otomatik çekimde fiyat doğru ürüne yazılır.
model HalSourceMapping {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  /// Kaynak: 'IBB' vb.
  source      String   @default("IBB")
  /// Kaynaktaki ürün adı (ör. "Çilek", "Domates (Sera)").
  sourceName  String   @map("source_name")
  /// Bizim katalog slug'ımız.
  productSlug String   @map("product_slug")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([tenantId, source, sourceName])
  @@map("hal_source_mappings")
}

/// Günlük hal fiyatı girişi — append-only (her giriş yeni satır, zaman damgalı).
/// Günlük ortalama bu satırlardan hesaplanır; geçmiş asla üzerine yazılmaz.
/// v1.1: hal günde 1 kez yayımlanır → time_slot nullable.
model HalPriceEntry {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  productSlug String   @map("product_slug")
  /// Fiyat (kuruş/birim).
  price       Int
  unit        String?
  /// Hangi güne ait (günlük liste).
  date        DateTime @db.Date
  /// Opsiyonel slot (v1.1 sonrası genelde null).
  timeSlot    String?  @map("time_slot")
  /// Kaynak: MANUAL | AUTO | kaynak adı.
  source      String?
  capturedBy  String?  @map("captured_by")
  capturedAt  DateTime @default(now()) @map("captured_at") @db.Timestamptz(6)

  @@index([tenantId, date])
  @@index([tenantId, productSlug, date])
  @@map("hal_price_entries")
}

/// Rakip grubu (Premium/Orta/İndirim/Hızlı/Lokal — Teknik doküman Bölüm 3.3).
model CompetitorGroup {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  competitors Competitor[]

  @@unique([tenantId, name])
  @@map("competitor_groups")
}

/// Rakip işletme.
model Competitor {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  groupId   String   @map("group_id") @db.Uuid
  type      String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  group  CompetitorGroup        @relation(fields: [groupId], references: [id])
  prices CompetitorPriceEntry[]

  @@index([tenantId])
  @@map("competitors")
}

/// Rakip fiyatı girişi — append-only (zaman damgalı; geçmiş korunur).
model CompetitorPriceEntry {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  productSlug  String   @map("product_slug")
  competitorId String   @map("competitor_id") @db.Uuid
  price        Int
  source       String?
  date         DateTime @db.Date
  capturedBy   String?  @map("captured_by")
  capturedAt   DateTime @default(now()) @map("captured_at") @db.Timestamptz(6)

  competitor Competitor @relation(fields: [competitorId], references: [id])

  @@index([tenantId, productSlug, date])
  @@map("competitor_price_entries")
}

/// Maliyet bileşenleri (Teknik doküman Bölüm 3.3). scope ile kapsanır:
/// GLOBAL (ref_id=''), PRODUCT (ref_id=slug), CATEGORY (ref_id=kategori).
/// En-spesifik satır kazanır (PRODUCT > GLOBAL). Para alanları kuruş.
model CostComponent {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  scope          String
  refId          String   @default("") @map("ref_id")
  fireRate       Float    @default(0) @map("fire_rate")
  packaging      Int      @default(0)
  labor          Int      @default(0)
  fuel           Int      @default(0)
  coldStorage    Int      @default(0) @map("cold_storage")
  amortization   Int      @default(0)
  commissionRate Float    @default(0) @map("commission_rate")
  taxRate        Float    @default(0) @map("tax_rate")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, scope, refId])
  @@map("cost_components")
}

/// Otomatik indirim (clearance) kuralı: yeni alım yapılmayan ama stoğu süren
/// ürünlerin fiyatı her gün kurala göre düşer, Fırsatlar'a düşer.
/// En-spesifik kazanır (PRODUCT > CATEGORY); mode=EXCLUDE ürünü kapsamdan çıkarır.
model MarkdownRule {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  scope          String // CATEGORY | PRODUCT
  refId          String   @map("ref_id") // kategori/ürün slug
  mode           String   @default("PRICE_DECAY") // PRICE_DECAY (fiyatın %X'i/gün) | MARGIN_DECAY (karın %X'i/gün) | EXCLUDE
  pct            Float    @default(0.05) // günlük indirim oranı (0-1)
  staleDays      Int      @default(2) @map("stale_days") // kaç gün alım/stok girişi yoksa "eriyor"
  allowBelowCost Boolean  @default(false) @map("allow_below_cost") // zararına satışa izin
  maxTotalOffPct Float    @default(0.5) @map("max_total_off_pct") // toplam indirim tavanı (taban fiyata göre)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([tenantId, scope, refId])
  @@map("markdown_rules")
}

/// Kasa oturumu: açılış bakiyesiyle açılır, gün sonunda sayımla kapanır.
/// Beklenen = açılış + girişler − çıkışlar; fark = sayılan − beklenen.
model RegisterSession {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  openingFloat  Int       @map("opening_float") // kuruş
  openedBy      String?   @map("opened_by")
  openedAt      DateTime  @default(now()) @map("opened_at") @db.Timestamptz(6)
  closedAt      DateTime? @map("closed_at") @db.Timestamptz(6)
  closedBy      String?   @map("closed_by")
  countedClose  Int?      @map("counted_close") // kapanışta sayılan (kuruş)
  expectedClose Int?      @map("expected_close") // kapanışta hesaplanan (kuruş)
  note          String?

  movements CashMovement[]

  @@index([tenantId, openedAt])
  @@map("register_sessions")
}

/// Kasa hareketi: giriş (teslim edilen kapıda-ödeme siparişi, elle tahsilat)
/// ya da çıkış (hal alımı, masraf). Sipariş/alım otomatik düşer (kasa açıksa).
model CashMovement {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  /// null = askıda (kasa kapalıyken düşen otomatik kayıt); kasa açılınca oturuma bağlanır.
  sessionId String?  @map("session_id") @db.Uuid
  type      String // IN | OUT
  category  String   @default("OTHER") // SALE | HAL_PURCHASE | EXPENSE | DEPOSIT | WITHDRAWAL | OTHER
  amount    Int // kuruş, pozitif
  note      String?
  refCode   String?  @map("ref_code") // sipariş kodu vb. (mükerrer kaydı önler)
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  session RegisterSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([tenantId, sessionId])
  @@map("cash_movements")
}

/// Üründen bağımsız genel gider (kira, ambalaj toplu alım, işçilik, kart komisyonu…).
/// Birim maliyete GİRMEZ; kâr/zarar raporunda döneme yansır.
/// kind=FIXED → amount (kuruş, period'a göre prorata); kind=RATE → rate (ciro oranı).
model OverheadCost {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  name       String
  category   String    @default("OTHER") // RENT | PACKAGING | LABOR | FUEL | COMMISSION | OTHER
  kind       String    @default("FIXED") // FIXED (tutar) | RATE (ciro yüzdesi)
  amount     Int       @default(0) // FIXED: kuruş
  rate       Float     @default(0) // RATE: oran (0.03 = %3)
  period     String    @default("MONTHLY") // MONTHLY | ONE_TIME (FIXED için)
  incurredAt DateTime? @map("incurred_at") @db.Timestamptz(6) // ONE_TIME tarihi
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId, isActive])
  @@map("overhead_costs")
}

/// Kalıcı fiyat kuralı (Teknik §3.3 pricing_rules). En-spesifik alan kazanır:
/// PRODUCT(slug) > CATEGORY(slug) > GLOBAL(''). Öneri/çözümde varsayılan
/// strateji + hedef/taban marjı sağlar (ör. sebzede taban %25, yöreselde %40).
model PricingRule {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  scope         String   // GLOBAL | CATEGORY | PRODUCT
  refId         String   @default("") @map("ref_id")
  /// Varsayılan strateji (opsiyonel; boşsa çağrı belirler).
  strategy      String?
  /// Hedef net marj (0..1) ve taban net marj (0..1). Motor tabanın altına inmez.
  targetMargin  Float?   @map("target_margin")
  floorMargin   Float?   @map("floor_margin")
  psychological Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, scope, refId])
  @@map("pricing_rules")
}

/// Hal alımı + ±500 g tartı mutabakatı. Yalnızca ham girdiler saklanır;
/// efektif maliyet/risk okuma anında packages/pricing ile hesaplanır.
model HalPurchase {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  /// Ürün slug'ı (katalog gelince products FK'sine bağlanacak).
  productSlug String?  @map("product_slug")
  recordedKg  Float    @map("recorded_kg")
  actualKg    Float?   @map("actual_kg")
  totalPaid   Int      @map("total_paid")
  precisionKg Float    @map("precision_kg")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId, productSlug])
  @@map("hal_purchases")
}

/// Havuz/dağıtımlı maliyet dönem kaydı. Tahsis + önizleme okuma anında
/// packages/pricing.directCost ile hesaplanır (previewProduct girdisi jsonb).
model CostPool {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  period           String
  totalLabor       Int      @map("total_labor")
  totalFuel        Int      @map("total_fuel")
  totalColdStorage Int?     @map("total_cold_storage")
  totalAmortization Int?    @map("total_amortization")
  totalVolumeKg    Float    @map("total_volume_kg")
  /// Opsiyonel ürün-bazlı girdiler (halAvg, fireRate, packaging, commissionRate).
  previewProduct   Json?    @map("preview_product")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId, period])
  @@map("cost_pool_entries")
}
