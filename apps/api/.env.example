# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# Yerel geliştirmede docker compose up -d ile gelen PostGIS'e bağlanır.
DATABASE_URL="postgresql://kabzimall:kabzimall@localhost:5432/kabzimall?schema=public"
PORT=3001

# Ortam: production'da JWT_SECRET zorunlu (yoksa uygulama BAŞLAMAZ — bilinçli),
# Swagger kapanır, CORS yalnız CORS_ORIGINS'e açılır.
# NODE_ENV=production

# Auth — üretimde güçlü, rastgele değerler kullanın (ör. openssl rand -hex 32).
JWT_SECRET="dev-secret-change-me-in-prod"
# Müşteri oturumları için AYRI anahtar (boşsa JWT_SECRET'ten türetilir).
# CUSTOMER_JWT_SECRET=""
AUTH_SEED_EMAIL="admin@kabzimall.local"
AUTH_SEED_PASSWORD="kabzimall123"

# CORS (yalnız production'da uygulanır) — panel ve vitrin adresleri, virgülle:
# CORS_ORIGINS="https://panel.kabzimall.com,https://kabzimall.com"

# E-posta (boşsa LOG modu: gönderilecek mail konsola yazılır, akış bloklanmaz).
# SMTP_HOST=""
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASS=""
# MAIL_FROM="KabzıMall <siparis@kabzimall.com>"

# AI sabah brifingi (boşsa kural bazlı özet üretilir).
# ANTHROPIC_API_KEY=""
# AI_BRIEF_MODEL="claude-sonnet-5"
